-- Skin Changer
do
    local SC = shared.vanity['Character']['Utilities']['Skin Changer']
    if SC and SC['Enabled'] then
        local RS           = game:GetService('ReplicatedStorage')
        local SkinAssets   = RS:FindFirstChild('SkinAssets')
        local SkinModules  = RS:FindFirstChild('SkinModules')
        local AppliedSkins = {}

        local function ApplySkin(Tool, SkinName)
            if not SkinName or SkinName == '' then return end
            local skinAsset = SkinAssets and SkinAssets:FindFirstChild(SkinName)
            if not skinAsset then return end
            local Default = Tool:FindFirstChild('Default')
            if not Default then return end
            local Mesh = Default:FindFirstChild('Mesh')
            if not Mesh then return end
            for _, child in next, Mesh:GetChildren() do
                if child:IsA('SpecialMesh') or child:IsA('FileMesh') then
                    pcall(function() child.TextureId = skinAsset:GetAttribute('TextureId') or '' end)
                end
            end
            local Handle = Tool:FindFirstChild('Handle')
            if Handle then
                local hMesh = Handle:FindFirstChildOfClass('SpecialMesh') or Handle:FindFirstChildOfClass('FileMesh')
                if hMesh and skinAsset:GetAttribute('TextureId') then
                    pcall(function() hMesh.TextureId = skinAsset:GetAttribute('TextureId') end)
                end
            end
            AppliedSkins[Tool] = SkinName
        end

        local function ProcessTool(Tool)
            if not Tool:IsA('Tool') then return end
            local Skins = SC['Skins']
            local SkinName = Skins[Tool.Name]
            if SkinName and SkinName ~= '' then
                ApplySkin(Tool, SkinName)
            end
        end

        local function ProcessCharacter(Character)
            for _, child in next, Character:GetChildren() do
                ProcessTool(child)
            end
            Character.ChildAdded:Connect(ProcessTool)
        end

        local function ProcessBackpack(Backpack)
            for _, child in next, Backpack:GetChildren() do
                ProcessTool(child)
            end
            Backpack.ChildAdded:Connect(ProcessTool)
        end

        if LocalPlayer.Character then
            ProcessCharacter(LocalPlayer.Character)
            local bp = LocalPlayer:FindFirstChildOfClass('Backpack')
            if bp then ProcessBackpack(bp) end
        end

        local scCharConn = LocalPlayer.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            ProcessCharacter(char)
            local bp = LocalPlayer:WaitForChild('Backpack', 5)
            if bp then ProcessBackpack(bp) end
        end)
        onCleanup(function() pcall(function() scCharConn:Disconnect() end) end)
    end
end

