            end
            ArmorBuying = false
        end)
    end)
    onCleanup(function() pcall(function() armorConn:Disconnect() end) end)
end

-- Inventory Sorter
do
    local SorterActive = false
    local sorterConn = UserInputService.InputBegan:Connect(function(Input, GameProcessed)
        if GameProcessed then return end
        local cfg = shared.vanity['Character']['Utilities']['Inventory Sorter']
        if not cfg or not cfg['Enabled'] then return end
        local SorterKey = shared.vanity['Keybinds']['Inventory Sorter']
        if not SorterKey then return end
        local match = false
        pcall(function()
            if Input.KeyCode == Enum.KeyCode[SorterKey:upper()] then match = true end
        end)
        if not match then return end
        if SorterActive then return end
        task.spawn(function()
            SorterActive = true
            local Character = LocalPlayer.Character
            if not Character then SorterActive = false; return end
            local Backpack = LocalPlayer:FindFirstChildOfClass('Backpack')
            if not Backpack then SorterActive = false; return end

            local GunOrder = cfg['Order']
            local OrderV   = 10 - #GunOrder

            -- Move all tools to a temp folder to reset slot order
            local FakeFolder = Instance.new('Folder')
            FakeFolder.Name   = 'SorterTemp'
            FakeFolder.Parent = workspace
            for _, v in next, Backpack:GetChildren() do
                if v:IsA('Tool') then
                    v.Parent = FakeFolder
                end
            end

            -- Return weapons in the desired order
            for _, Name in next, GunOrder do
                local Gun = FakeFolder:FindFirstChild(Name)
                if Gun then
                    Gun.Parent = Backpack
                    task.wait(0.05)
                else
                    OrderV = OrderV + 1
                end
            end

            -- Return consumables first (they go to the back)
            for _, v in next, FakeFolder:GetChildren() do
                if v:FindFirstChild('Drink') or v:FindFirstChild('Eat') then
                    v.Parent = Backpack
                    OrderV   = OrderV - 1
                end
            end

            -- Insert placeholders to push remaining weapons into correct slots
            if OrderV > 0 then
                for _ = 1, OrderV do
                    local PlaceHolder = Instance.new('Tool')
                    PlaceHolder.Name           = ''
                    PlaceHolder.ToolTip        = 'PlaceHolder'
                    PlaceHolder.GripPos        = Vector3.new(0, 1, 0)
                    PlaceHolder.RequiresHandle = false
                    PlaceHolder.Parent         = Backpack
                end
            end

            -- Return any remaining tools
            for _, v in next, FakeFolder:GetChildren() do
                if v:IsA('Tool') then
                    v.Parent = Backpack
                end
            end

            -- Clean up placeholders
            for _, v in next, Backpack:GetChildren() do
                if v.Name == '' then v:Destroy() end
            end

            FakeFolder:Destroy()
            task.wait(0.5)
            SorterActive = false
        end)
    end)
    onCleanup(function() pcall(function() sorterConn:Disconnect() end) end)
end
