                    if IR['Enabled'] and self == MainEvent and method == 'FireServer' then
                        local eventName = tostring(args[1])
                        if eventName == 'ShootGun' or eventName == 'Shoot'
                            or eventName == 'DoubleBarrel' or eventName == 'Double-Barrel'
                            or eventName == 'Shotgun' then
                            local hitPos    = args[3]
                            local muzzlePos = args[6]
                            if typeof(hitPos) ~= 'Vector3' and typeof(args[2]) == 'Vector3' then
                                hitPos = args[2]
                            end
                            if typeof(hitPos) == 'Vector3' and typeof(muzzlePos) == 'Vector3' then
                                local distance = (hitPos - muzzlePos).Magnitude
                                if distance > 15 then
                                    local direction  = (hitPos - muzzlePos).Unit
                                    local fakeHitPos = muzzlePos + (direction * IR['Bypass Pos'])
                                    if typeof(args[3]) == 'Vector3' then args[3] = fakeHitPos end
                                    if typeof(args[5]) == 'Vector3' then args[5] = fakeHitPos end
                                    if typeof(args[2]) == 'Vector3' and args[2] == hitPos then
                                        args[2] = fakeHitPos
                                    end
                                end
                            end
                        end
                    end
                    return oldNc(self, unpack(args))
                end))
            end

            if GunHandlerModule and hookfunction then
                local GunHandler = require(GunHandlerModule)
                if GunHandler.getAim then
                    local oldGetAim
                    oldGetAim = hookfunction(GunHandler.getAim, function(hit, dist)
                        return oldGetAim(hit, IR['Enabled'] and IR['Range'] or dist)
                    end)
                end
                if GunHandler.shoot then
                    local oldShoot
                    oldShoot = hookfunction(GunHandler.shoot, function(data)
                        if IR['Enabled'] and typeof(data) == 'table' then
                            data.Range = IR['Range']
                        end
                        return oldShoot(data)
                    end)
                end
            end
        end)
    end
end

local function setupCharacter(char)
    if not char then return end
    local hum = char:FindFirstChildOfClass('Humanoid')
    if not hum then return end
    local defaultJP = hum.JumpPower

    hum:GetPropertyChangedSignal('JumpPower'):Connect(function()
        local MOV = shared.vanity['Character']['Movement']
        if not MOV['No Jump Cooldown'] then return end
        if hum.JumpPower == 0 then
            local JP = MOV['Jump Power']
            if JP['Enabled'] and MOV_JumpActive and not JP['Spiderman Mode'] then
                local key  = getMovKey(char)
                local mult = JP[key] and JP[key]['Multiplier'] or 1
                hum.JumpPower = mult * 100
            else
                hum.JumpPower = defaultJP
            end
        end
    end)

    hum.StateChanged:Connect(function(_, newState)
        if not shared.vanity['Character']['Movement']['Anti Fall'] then return end
        if newState == Enum.HumanoidStateType.FallingDown
            or newState == Enum.HumanoidStateType.Ragdoll then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)

    local wallParams = RaycastParams.new()
    wallParams.FilterType = Enum.RaycastFilterType.Exclude
    wallParams.FilterDescendantsInstances = { char }

    local function isNearWall(hrp)
        local cf = hrp.CFrame
        for _, dir in ipairs({ cf.LookVector, -cf.LookVector, cf.RightVector, -cf.RightVector }) do
            if workspace:Raycast(hrp.Position, dir * 3, wallParams) then return true end
        end
        return false
    end

    local freefallStart = 0
    hum.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Freefall then
            freefallStart = tick()
        elseif newState == Enum.HumanoidStateType.Landed
            or newState == Enum.HumanoidStateType.Running then
            freefallStart = 0
        end
    end)

    UserInputService.JumpRequest:Connect(function()
        local JP = shared.vanity['Character']['Movement']['Jump Power']
        if not JP['Enabled'] or not MOV_JumpActive or not JP['Spiderman Mode'] then return end
        local hrp = char:FindFirstChild('HumanoidRootPart')
        if not hrp then return end
        if hum:GetState() ~= Enum.HumanoidStateType.Freefall then return end
        if freefallStart == 0 or (tick() - freefallStart) < 0.2 then return end
        if not isNearWall(hrp) then return end
        local key  = getMovKey(char)
        local mult = JP[key] and JP[key]['Multiplier'] or 1
        hum.JumpPower = mult * 100
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        local resetConn
        resetConn = hum.StateChanged:Connect(function(_, ns)
            if ns == Enum.HumanoidStateType.Freefall or ns == Enum.HumanoidStateType.Landed then
                resetConn:Disconnect()
                hum.JumpPower = defaultJP
            end
        end)
    end)
end

