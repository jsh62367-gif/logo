local function SA_GetClosestBodyPart(character)
    local mp = UserInputService:GetMouseLocation()
    local best, bd = nil, math.huge
    for _, name in ipairs(SA_AllHitParts) do
        local part = character:FindFirstChild(name)
        if part and part:IsA('BasePart') then
            local sp, on = Camera:WorldToViewportPoint(part.Position)
            if on then
                local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
                if d < bd then bd = d; best = part end
            end
        end
    end
    if not best then
        local camPos = Camera.CFrame.Position
        local fd = math.huge
        for _, name in ipairs(SA_AllHitParts) do
            local part = character:FindFirstChild(name)
            if part and part:IsA('BasePart') then
                local d = (part.Position - camPos).Magnitude
                if d < fd then fd = d; best = part end
            end
        end
    end
    return best
end

local function SA_GetClosestPartToCursor(character)
    local mp = UserInputService:GetMouseLocation()
    local best, bd = nil, math.huge
    for _, part in pairs(character:GetChildren()) do
        if not part:IsA('BasePart') then continue end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if on then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < bd then bd = d; best = part end
        end
    end
    return best
end

local function SA_GetNearestPointOnPart(part, plane, offset)
    local mp  = UserInputService:GetMouseLocation()
    local ray = Camera:ViewportPointToRay(mp.X, mp.Y)
    local intersection = ray.Origin + (ray.Direction * ray.Direction:Dot(part.Position - ray.Origin))
    local transform    = part.CFrame:PointToObjectSpace(intersection)
    local reduction    = offset or 0
    local reducedSize  = part.Size - (part.Size * reduction)
    if plane == 'Vertical' then
        reducedSize = reducedSize * Vector3.new(1, 1, 0)
    end
    local half = reducedSize / 2
    return part.CFrame * Vector3.new(
        math.clamp(transform.X, -half.X, half.X),
        math.clamp(transform.Y, -half.Y, half.Y),
        math.clamp(transform.Z, -half.Z, half.Z)
    )
end

local function SA_IsKnocked(char)
    local hum = char:FindFirstChildOfClass('Humanoid')
    if hum then
        local s = hum:GetState()
        if s == Enum.HumanoidStateType.Dead
            or s == Enum.HumanoidStateType.Physics
            or s == Enum.HumanoidStateType.Ragdoll then return true end
        if hum.Health > 0 and hum.Health <= 2 then return true end
    end
    local be = char:FindFirstChild('BodyEffects')
    if be then
        local k = be:FindFirstChild('K.O')
        if k and k.Value then return true end
    end
    return false
end

local function SA_GetClosestPlayer()
    local SA         = shared.vanity['Silent Aim']
    local fov        = SA['FOV']
    local fovEnabled = fov['Enabled']
    local mp         = UserInputService:GetMouseLocation()
    local limit      = (fovEnabled and fov['Size'] and ((fov['Size']['X'] + fov['Size']['Y']) / 2)) or math.huge
    local best, bd   = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        local hrp = char:FindFirstChild('HumanoidRootPart')
        if not hrp then continue end
        local sp, on = Camera:WorldToViewportPoint(hrp.Position)
        if sp.Z > 0 then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if (not fovEnabled or d <= limit) and d < bd then
                bd = d; best = player
            end
        end
    end
    return best
end

local function SA_ResolveHitPosition(character)
    local SA         = shared.vanity['Silent Aim']
    local hitPartCfg = SA['Hit Part']
    if type(hitPartCfg) == 'string' then
        local p = (hitPartCfg == 'Closest Part')
            and SA_GetClosestBodyPart(character)
            or  character:FindFirstChild(hitPartCfg)
            or  character:FindFirstChild('HumanoidRootPart')
        return p and p.Position or nil, p
    end
    local partName = hitPartCfg['Part'] or 'HumanoidRootPart'
    if partName == 'Nearest Point' then
        local p = SA_GetClosestPartToCursor(character)
        if p then
            local plane     = hitPartCfg['Plane'] or 'Vertical'
            local offsetKey = plane == 'Vertical' and 'Vertical' or 'Full'
            local offset    = (hitPartCfg['Offset'] and hitPartCfg['Offset'][offsetKey]) or 0.7
            local precision = hitPartCfg['Precision'] or 1
            local point     = SA_GetNearestPointOnPart(p, plane, offset)
            if precision < 1 then
                point = p.Position:Lerp(point, precision)
            end
            return point, p
        end
        local fb = character:FindFirstChild('HumanoidRootPart')
        return fb and fb.Position or nil, fb
    end
    local part = (partName == 'Closest Part')
        and SA_GetClosestBodyPart(character)
        or  character:FindFirstChild(partName)
        or  character:FindFirstChild('HumanoidRootPart')
    return part and part.Position or nil, part
end

local function AA_UpdatePosCache()
    local now = os.clock()
    if (now - AA_LastUpdate) < AA_SampleInterval then return end
    AA_LastUpdate = now
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild('HumanoidRootPart')
            if hrp then
                if not AA_PosCache[player] then AA_PosCache[player] = {} end
                local cache = AA_PosCache[player]
                local last  = cache[1]
                if not last or (now - last.t) >= AA_SampleInterval then
                    table.insert(cache, 1, { pos = hrp.Position, t = now })
                    if #cache > AA_CacheSize then cache[#cache] = nil end
                end
            end
        end
    end
    for player in pairs(AA_PosCache) do
        if not player.Parent then AA_PosCache[player] = nil end
    end
end

local function AA_GetDeltaVelocity(player)
    local cache = AA_PosCache[player]
    if not cache or #cache < 2 then return Vector3.zero end
    local newest = cache[1]
    local oldest = cache[math.min(#cache, 4)]
    local dt     = newest.t - oldest.t
    if dt <= 0.001 then return Vector3.zero end
    return (newest.pos - oldest.pos) / dt
end

local function AA_GetAimPart(char)
    local AA  = shared.vanity['Aim Assist']
    local cfg = AA['Hit Part']
    if type(cfg) == 'string' then
        if cfg == 'Closest Part' then return SA_GetClosestBodyPart(char) end
        return char:FindFirstChild(cfg) or char:FindFirstChild('HumanoidRootPart')
    end
    local partName = cfg['Part'] or 'Head'
    if partName == 'Nearest Point' then
        local p = SA_GetClosestPartToCursor(char)
        if p then
            local plane     = cfg['Plane'] or 'Vertical'
            local offsetKey = plane == 'Vertical' and 'Vertical' or 'Full'
            local offset    = (cfg['Offset'] and cfg['Offset'][offsetKey]) or 0.7
            local precision = cfg['Precision'] or 1
            local point     = SA_GetNearestPointOnPart(p, plane, offset)
            if precision < 1 then point = p.Position:Lerp(point, precision) end
            return p, point
        end
        return char:FindFirstChild('HumanoidRootPart'), nil
    end
    if partName == 'Closest Part' then return SA_GetClosestBodyPart(char), nil end
    return char:FindFirstChild(partName) or char:FindFirstChild('HumanoidRootPart'), nil
end

local function AA_GetClosestPlayer()
    local AA    = shared.vanity['Aim Assist']
    local fov   = AA['FOV']
    local mp    = UserInputService:GetMouseLocation()
    local limit = (fov['Enabled'] and fov['Size'] and ((fov['Size']['X'] + fov['Size']['Y']) / 2)) or math.huge
    local best, bd = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end
        if SA_IsKnocked(char) then continue end
        local hum = char:FindFirstChildOfClass('Humanoid')
        if not hum or hum.Health <= 0 then continue end
        local hrp = char:FindFirstChild('HumanoidRootPart')
        if not hrp then continue end
        local dist3d = (hrp.Position - Camera.CFrame.Position).Magnitude
        if dist3d > (AA['Max Range'] or math.huge) then continue end
        local sp, on = Camera:WorldToViewportPoint(hrp.Position)
        if on and sp.Z > 0 then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d <= limit and d < bd then bd = d; best = player end
        end
    end
    return best
end

