        local HRP = Character:FindFirstChild('HumanoidRootPart')
        if not HRP then return end
        local Ignored = workspace:FindFirstChild('Ignored')
        if not Ignored then return end
        local Shop = Ignored:FindFirstChild('Shop')
        if not Shop then return end
        local ArmorShop  = nil
        local LowestPrice = math.huge
        for _, ShopPart in next, Shop:GetChildren() do
            local itemName = string.lower(ShopPart.Name)
            if string.find(itemName, 'armor') then
                local priceStr = string.match(itemName, '%$(%d+)')
                local price    = priceStr and tonumber(priceStr) or math.huge
                if price < LowestPrice then
                    local Head     = ShopPart:FindFirstChild('Head')
                    local Detector = ShopPart:FindFirstChildOfClass('ClickDetector')
                    if Head and Detector then
                        ArmorShop  = { Head = Head, Detector = Detector }
                        LowestPrice = price
                    end
                end
            end
        end
        if not ArmorShop then return end
        ArmorBuying = true
        task.spawn(function()
            local ShopPos = ArmorShop.Head.Position - Vector3.new(0, 8.8, 0)
            local Detector = ArmorShop.Detector
            for _ = 1, 60 do
                if not HRP or not HRP.Parent then break end
                fireclickdetector(Detector)
                local OldCF = HRP.CFrame
                HRP.CFrame  = CFrame.new(ShopPos)
                RunService.RenderStepped:Wait()
                HRP.CFrame  = OldCF
