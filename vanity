do
    local ArmorBuying = false
    local armorConn = UserInputService.InputBegan:Connect(function(Input, GameProcessed)
        if GameProcessed then return end
        local cfg = shared.vanity['Character']['Utilities']['Purchase Armor']
        if not cfg or not cfg['Enabled'] then return end
        local ArmorKey = shared.vanity['Keybinds']['Purchase Armor']
