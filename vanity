local function TB_IsPlayerInFOV(player)
    local TB  = shared.vanity['Triggerbot']
    local fov = TB['FOV']
    if not fov['Enabled'] then return true end
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild('HumanoidRootPart')
    if not hrp then return false end
    local sp, on = Camera:WorldToViewportPoint(hrp.Position)
    if not on then return false end
    local mp = UserInputService:GetMouseLocation()
    local dx = math.abs(sp.X - mp.X)
    local dy = math.abs(sp.Y - mp.Y)
    return dx <= (fov['Size']['Width'] / 2) and dy <= (fov['Size']['Height'] / 2)
end

local function TB_IsOnPlayer()
    local char = LocalPlayer.Character
    if not char then return nil end
    local tool = char:FindFirstChildOfClass('Tool')
    if not tool then return nil end
    local mp = UserInputService:GetMouseLocation()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local tc = player.Character
        if not tc then continue end
        if SA_IsKnocked(tc) then continue end
        local hum = tc:FindFirstChildOfClass('Humanoid')
        if not hum or hum.Health <= 0 then continue end
        for _, part in pairs(tc:GetChildren()) do
            if part:IsA('BasePart') then
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
                    if d <= 15 then return player end
                end
            end
        end
    end
    return nil
end

local RawMeta     = getrawmetatable(game)
local oldIndex    = RawMeta.__index
local oldNamecall = RawMeta.__namecall
setreadonly(RawMeta, false)

RawMeta.__index = newcclosure(function(self, key)
    if not checkcaller() then
        local SA = shared.vanity['Silent Aim']
        if SA['Enabled'] and SA_TargetPart and SA_TargetPos then
            if self == Mouse and (key == 'Hit' or key == 'Target') then
                local pred = SA['Prediction']
                local vel  = SA_TargetPart.AssemblyLinearVelocity or SA_TargetPart.Velocity
                local pos  = SA_TargetPos
                if pred['Enabled'] then
                    local v = pred['Values']
                    pos = pos + Vector3.new(vel.X * v['X'], vel.Y * v['Y'], vel.Z * v['Z'])
                end
                if key == 'Hit'    then return CFrame.new(pos) end
                if key == 'Target' then return SA_TargetPart end
            end
        end
    end
    return oldIndex(self, key)
end)

RawMeta.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args   = { ... }
    if not checkcaller() then
        local SA = shared.vanity['Silent Aim']
        if SA['Enabled'] and SA_TargetPart and SA_TargetPos then
            local pred = SA['Prediction']
            local vel  = SA_TargetPart.AssemblyLinearVelocity or SA_TargetPart.Velocity
            local pos  = SA_TargetPos
            if pred['Enabled'] then
                local v = pred['Values']
                pos = pos + Vector3.new(vel.X * v['X'], vel.Y * v['Y'], vel.Z * v['Z'])
            end
            if method == 'FindPartOnRayWithIgnoreList'
                or method == 'FindPartOnRayWithWhitelist'
                or method == 'FindPartOnRay' then
                args[1] = Ray.new(Camera.CFrame.Position, (pos - Camera.CFrame.Position).Unit * 1000)
                return oldNamecall(self, unpack(args))
            elseif method == 'Raycast' then
                args[2] = (pos - args[1]).Unit * 1000
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

setreadonly(RawMeta, true)

onCleanup(function()
    pcall(function()
        setreadonly(RawMeta, false)
        RawMeta.__index    = oldIndex
        RawMeta.__namecall = oldNamecall
        setreadonly(RawMeta, true)
    end)
end)

local function getMovKey(char)
    local tool = char:FindFirstChildOfClass('Tool')
    local hum  = char:FindFirstChildOfClass('Humanoid')
    local isReload = false
    if tool then
        local ammo = tool:FindFirstChild('Ammo')
        if ammo and ammo.Value == 0 then isReload = true end
        if not isReload then
            local reloading = tool:FindFirstChild('Reloading')
            if reloading and reloading.Value then isReload = true end
        end
    end
    local isLowHealth = hum and hum.Health > 0 and hum.Health <= 25
    if isLowHealth then return 'Low Health' end
    if isReload    then return 'Reload' end
    return 'Normal'
end
local function rgb(c)
    return string.format('rgb(%d,%d,%d)',
        math.floor(c.R * 255 + 0.5),
        math.floor(c.G * 255 + 0.5),
        math.floor(c.B * 255 + 0.5))
end

local inputConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    local binds      = shared.vanity['Keybinds']
    local multibinds = shared.vanity['Multibinds']
    local handledByMulti = {}

    for _, group in ipairs(multibinds) do
        if not group['Enabled'] then continue end
        local key = group['Key']
        if not key then continue end
        local matched = false
        pcall(function() matched = input.KeyCode == Enum.KeyCode[key:upper()] end)
        if not matched then continue end

        local allOn = true
        for _, feat in ipairs(group['Features']) do
            if feat == 'Silent Aim'  then if not shared.vanity['Silent Aim']['Enabled'] then allOn = false end
            elseif feat == 'Aim Assist'  then if not AA_Locked then allOn = false end
            elseif feat == 'Triggerbot'  then if not TB_State  then allOn = false end
            elseif feat == 'ESP'         then if not shared.vanity['Name ESP']['Enabled'] then allOn = false end
            elseif feat == 'Walk Speed'  then if not MOV_SpeedActive then allOn = false end
            elseif feat == 'Jump Power'  then if not MOV_JumpActive  then allOn = false end
            end
        end

        local turnOn = not allOn

        for _, feat in ipairs(group['Features']) do
            local featureKey = nil
            if     feat == 'Silent Aim'  then featureKey = binds['Silent Aim Toggle']
