do
    local COOLDOWN_KEYS = {
        'FireRate','Firerate','fireRate','firerate',
        'Cooldown','cooldown','CoolDown',
        'FireDelay','fireDelay','FireCooldown',
        'ShootCooldown','shootCooldown',
        'ShootingCooldown','shootingCooldown',
        'Delay','delay',
        'TimeBetweenShots','timeBetweenShots',
        'ShotCooldown','shotCooldown',
    }
    local COOLDOWN_SET = {}
    for _, k in ipairs(COOLDOWN_KEYS) do COOLDOWN_SET[k] = true end

    local gcCache      = setmetatable({}, { __mode = 'k' })
    local lastGcScan   = 0
    local GC_INTERVAL  = 15
    local delayFrame   = 0
    local lastDCTool   = nil
    local patchPending = false

    local function getDelay(tool)
        local DC   = shared.vanity['Character']['Gun Modifications']['Delay Changer']
        local weps = DC['Weapons']
        if tool and weps and weps[tool.Name] ~= nil then
            return weps[tool.Name]
        end
        return DC['Amount'] or 0
    end

    local function patchConnections(tool, delayValue)
        if not getconnections then return end
        pcall(function()
            for _, conn in ipairs(getconnections(tool.Activated)) do
                local func = conn.Function
                if not func then continue end
                local info = debug.getinfo and debug.getinfo(func)
                if not info then continue end
                for i = 1, (info.nups or 0) do
                    local ok, val = pcall(debug.getupvalue, func, i)
                    if not ok or val == nil then continue end
                    if type(val) == 'table' then
                        for key, v in pairs(val) do
                            if COOLDOWN_SET[key] and type(v) == 'number' and v > delayValue then
                                pcall(rawset, val, key, delayValue)
                            end
                        end
                    elseif type(val) == 'number' and val > 0 and val < 10 then
                        pcall(debug.setupvalue, func, i, delayValue)
                    end
                end
            end
        end)
    end

    local function patchValueBases(tool, delayValue)
        for _, child in ipairs(tool:GetDescendants()) do
            if child:IsA('NumberValue') or child:IsA('IntValue') then
                if COOLDOWN_SET[child.Name] then
                    child.Value = delayValue
                end
            end
        end
        if tool:GetAttribute('ShootingCooldown') then
            tool:SetAttribute('ShootingCooldown', delayValue)
        end
    end

    local function gcScan()
        if not getgc then return end
        pcall(function()
            local startTime = tick()
            for _, obj in ipairs(getgc(true)) do
                if tick() - startTime > 0.06 then break end
                if type(obj) == 'table' and not gcCache[obj] then
                    for key in pairs(obj) do
                        if COOLDOWN_SET[key] then gcCache[obj] = true; break end
                    end
                end
            end
        end)
    end

    local function applyDelayPatches(tool, delayValue)
        patchPending = false
        if not shared.vanity['Character']['Gun Modifications']['Delay Changer']['Enabled'] then return end
        pcall(patchConnections, tool, delayValue)
        pcall(patchValueBases,  tool, delayValue)
    end

    local dcConn = RunService.Heartbeat:Connect(function()
        if not isAlive() then return end
        local DC = shared.vanity['Character']['Gun Modifications']['Delay Changer']
        if not DC['Enabled'] then return end
        local char = LocalPlayer.Character
        if not char then return end
        local tool = char:FindFirstChildOfClass('Tool')
        if not tool then return end

        local hasScript = tool:FindFirstChildOfClass('LocalScript')
            or tool:FindFirstChildOfClass('Script')
            or tool:FindFirstChildOfClass('ModuleScript')
        if not hasScript then return end

        local delayValue = getDelay(tool)
        delayFrame = delayFrame + 1

        local toolChanged = tool ~= lastDCTool
        if toolChanged then
            lastDCTool = tool
            if not patchPending then
                patchPending = true
                task.defer(applyDelayPatches, tool, delayValue)
            end
        end

        if not toolChanged and delayFrame % 12 == 0 then
            task.defer(applyDelayPatches, tool, delayValue)
        end

        local now = tick()
        if now - lastGcScan >= GC_INTERVAL then
            lastGcScan = now
            task.spawn(gcScan)
        end

        if delayFrame % 8 == 0 then
            for tbl in pairs(gcCache) do
                pcall(function()
                    for key, v in pairs(tbl) do
                        if COOLDOWN_SET[key] and type(v) == 'number' and v > delayValue then
                            tbl[key] = delayValue
                        end
                    end
                end)
            end
        end
    end)
    onCleanup(function() pcall(function() dcConn:Disconnect() end) end)
end

do
    local function applySpread(...)
        local SpreadCfg = shared.vanity['Character']['Gun Modifications']['Spread Changer']
        if not SpreadCfg['Enabled'] then return nil end
        local args = { ... }
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass('Tool')
        local multiplier = SpreadCfg['Amount'] or 0
        if tool and SpreadCfg['Weapons'][tool.Name] ~= nil then
            multiplier = SpreadCfg['Weapons'][tool.Name]
        end
        local placeId = game.PlaceId
        if placeId == 75947843575468 or placeId == 103176029075121 then
            local isSpread = (#args == 0)
                or (args[1] and args[2] and args[1] < 0 and args[2] > 0 and math.abs(args[1]) <= 0.5)
            if isSpread then
                return multiplier == 0 and 0.001 or multiplier, true
            end
            return nil
        else
            return multiplier, false
        end
    end

    if hookfunction then
        local oldRandom
        oldRandom = hookfunction(math.random, newcclosure(function(...)
            if checkcaller() then return oldRandom(...) end
            local mult, isSpreadPattern = applySpread(...)
            if mult ~= nil then
                local args = { ... }
                if isSpreadPattern then
                    return oldRandom(...) * mult
                else
                    if #args == 0 then return oldRandom() * mult end
                    if #args == 1 then return oldRandom(args[1]) * mult end
                    if #args == 2 then
                        local res    = oldRandom(args[1], args[2])
                        local center = (args[1] + args[2]) / 2
                        return center + (res - center) * mult
                    end
                end
            end
            return oldRandom(...)
        end))
        onCleanup(function() pcall(function() hookfunction(math.random, oldRandom) end) end)
    else
        pcall(function()
            local m = math
            setreadonly(m, false)
            local oldRandom = m.random
            m.random = newcclosure(function(...)
                if checkcaller and checkcaller() then return oldRandom(...) end
                local mult, isSpreadPattern = applySpread(...)
                if mult ~= nil then
                    local args = { ... }
                    if isSpreadPattern then
                        return oldRandom(...) * mult
                    else
                        if #args == 0 then return oldRandom() * mult end
                        if #args == 1 then return oldRandom(args[1]) * mult end
                        if #args == 2 then
                            local res    = oldRandom(args[1], args[2])
                            local center = (args[1] + args[2]) / 2
                            return center + (res - center) * mult
                        end
                    end
                end
                return oldRandom(...)
            end)
            onCleanup(function()
                pcall(function()
                    setreadonly(m, false)
                    m.random = oldRandom
                    setreadonly(m, true)
                end)
            end)
        end)
    end
end

